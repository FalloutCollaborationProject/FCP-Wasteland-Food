<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--__________ Wasteland Food Recipes __________-->

    <!-- Base Recipe -->

    <RecipeDef Name="FCP_CookWastelandMealBase" Abstract="True">
        <fixedIngredientFilter>
            <categories>
                <li>FoodRaw</li>
            </categories>
            <specialFiltersToDisallow>
                <li>AllowPlantFood</li>
            </specialFiltersToDisallow>
        </fixedIngredientFilter>
        <defaultIngredientFilter>
            <categories>
                <li>FoodRaw</li>
            </categories>
            <disallowedCategories>
                <li>EggsUnfertilized</li>
            </disallowedCategories>
            <disallowedThingDefs>
                <li>Meat_Human</li>
                <li>Meat_Megaspider</li>
                <li>InsectJelly</li>
                <li MayRequire="Ludeon.RimWorld.Anomaly">Meat_Twisted</li>
            </disallowedThingDefs>
        </defaultIngredientFilter>
        <workSpeedStat>CookSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_CookMeal</soundWorking>
        <allowMixingIngredients>false</allowMixingIngredients>
        <workSkill>Cooking</workSkill>
    </RecipeDef>

    <!-- Simple Fueled Station -->

    <RecipeDef Name="FCP_CookWastelandMeal_Simple" ParentName="FCP_CookWastelandMealBase" Abstract="True">
        <recipeUsers>
            <li>FCP_Production_Cooking_Station_Fueled_Simple</li>
            <li>FCP_Production_Cooking_Station_Fueled_Complex</li>
            <li>FCP_Production_Cooking_Station_Electric</li>
        </recipeUsers>
    </RecipeDef>

    <!-- Complex Fueled Station -->

    <RecipeDef Name="FCP_CookWastelandMeal_Complex" ParentName="FCP_CookWastelandMealBase" Abstract="True">
        <recipeUsers>
            <li>FCP_Production_Cooking_Station_Fueled_Complex</li>
            <li>FCP_Production_Cooking_Station_Electric</li>
        </recipeUsers>
    </RecipeDef>

    <!-- Electric Station -->

    <RecipeDef Name="FCP_CookWastelandMeal_Electric" ParentName="FCP_CookWastelandMealBase" Abstract="True">
        <recipeUsers>
            <li>FCP_Production_Cooking_Station_Electric</li>
        </recipeUsers>
    </RecipeDef>

    <!--_____ Black Blood Sausage _____-->

    <RecipeDef ParentName="FCP_CookWastelandMeal_Complex">
        <defName>FCP_Cook_Black_Blood_Sausage</defName>
        <label>cook black blood sausage</label>
        <description>Cook black blood sausage from wasteland meat and blood.</description>
        <jobString>Cooking black blood sausage.</jobString>
        <workAmount>450</workAmount>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>FCP_Meat_Beast</li>
                        <li>FCP_Meat_Prime_Beast</li>
                        <li>FCP_Meat_Bug</li>
                        <li>FCP_Meat_Plumb_Bug</li>
                        <li>FCP_Meat_Crab</li>
                        <li>FCP_Meat_Succulent_Fish</li>
                        <li>FCP_Meat_Herptile</li>
                        <li>FCP_Meat_Prime_Herptile</li>
                        <li>FCP_Meat_Poultry</li>
                        <li>FCP_Meat_Plumb_Poultry</li>
                        <li>FCP_Meat_Varmint</li>
                        <li>FCP_Meat_Prime_Varmint</li>
                    </thingDefs>
                </filter>
                <count>8</count>
            </li>
        </ingredients>
        <products>
            <FCP_Food_Black_Blood_Sausage>1</FCP_Food_Black_Blood_Sausage>
        </products>
        <skillRequirements>
            <Cooking>3</Cooking>
        </skillRequirements>
    </RecipeDef>

